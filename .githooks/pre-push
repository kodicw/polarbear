#!/usr/bin/env bash
# pre-push hook: run flake check and optionally format nix files

set -e

echo "Running nix flake check..."
nix flake check --accept-flake-config

# Build docs to ensure they generate correctly
echo "Building docs package..."
nix build --accept-flake-config .#packages.x86_64-linux.docs

# Try to format nix files if nixfmt is available
if command -v nixfmt &> /dev/null; then
    echo "Formatting nix files with nixfmt..."
    find . -name "*.nix" -type f -not -path "./.git/*" -exec nixfmt {} \;
    git add -A
else
    echo "Skipping formatting (nixfmt not installed)"
fi

echo "Pre-push checks passed!"